#!/usr/bin/env bash
# Marca momento em gravação ativa — pra hotkey (Super+Shift+M)

set -eu

SOCK="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/recordo.sock"

if [[ ! -S "$SOCK" ]]; then
    notify-send -a Recordo -u critical -i dialog-error "Recordo" "Daemon offline."
    exit 1
fi

# Status JSON é estruturado: parser robusto via jq -e (jq é dep do setup.sh).
# Fallback p/ grep só se jq sumir do PATH por algum motivo.
STATUS=$(recordo --status 2>/dev/null || true)
if command -v jq >/dev/null; then
    if ! echo "$STATUS" | jq -e '.recording == true' >/dev/null 2>&1; then
        notify-send -a Recordo -i dialog-warning "Recordo" "Nenhuma gravação ativa."
        exit 1
    fi
else
    # legacy fallback (não deveria acontecer — jq é instalado pelo setup.sh)
    if ! echo "$STATUS" | grep -qE '"recording"\s*:\s*true'; then
        notify-send -a Recordo -i dialog-warning "Recordo" "Nenhuma gravação ativa."
        exit 1
    fi
fi

if command -v zenity >/dev/null; then
    TEXT=$(zenity --entry --title="Marcar momento" --timeout=15 \
           --text="Nota (vazio = só timestamp):" 2>/dev/null || echo "")
else
    TEXT=""
fi

recordo --mark "$TEXT"
