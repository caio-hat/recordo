#!/usr/bin/env bash
# Recordo tray launcher — chama python -m recordo --tray usando venv dedicado
set -eu

VENV_PY="$HOME/.local/share/recordo/venv/bin/python"

if [[ ! -x "$VENV_PY" ]]; then
    notify-send -a Recordo -u critical -i dialog-error "Recordo Tray" \
        "Venv ausente em $VENV_PY. Rode: bash setup.sh"
    exit 1
fi

exec "$VENV_PY" -m recordo --tray "$@"
